---
/**
 * Renders skill categories as compact comma-separated lists.
 * For print resume — no pills, just space-efficient text.
 */
interface SkillCategory {
  data: {
    name: string;
    sortOrder: number;
    resumeSection: 'sidebar' | 'main';
    items: string[];
    note?: string;
  };
}

interface Props {
  skills: SkillCategory[];
}

const { skills } = Astro.props;
const sorted = [...skills].sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<section class="resume-skills">
  <h2 class="section-heading">Skills</h2>
  {sorted.map((skill) => (
    <div class="skill-group">
      <span class="skill-name">{skill.data.name}:</span>
      <span class="skill-items">{skill.data.items.join(', ')}</span>
      {skill.data.note && (
        <span class="skill-note"> — {skill.data.note}</span>
      )}
    </div>
  ))}
</section>

<style>
  .resume-skills {
    margin-bottom: 0.75rem;
  }

  .section-heading {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #0E5484;
    border-bottom: 1.5px solid #0E5484;
    padding-bottom: 0.15rem;
    margin: 0 0 0.4rem 0;
  }

  .skill-group {
    margin-bottom: 0.25rem;
    font-size: 0.65rem;
    line-height: 1.35;
    break-inside: avoid;
  }

  .skill-name {
    font-weight: 600;
    color: #2d2d2d;
  }

  .skill-items {
    color: #444;
  }

  .skill-note {
    color: #666;
    font-style: italic;
    font-size: 0.65rem;
  }
</style>
