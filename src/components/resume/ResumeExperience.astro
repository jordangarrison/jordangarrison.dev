---
/**
 * Renders experience entries with dates, titles, summaries.
 * Condensed: professional only, brief summary, no highlights/promotions/body.
 * Full: all entries, highlights, promotions, expanded body.
 *
 * Body content (Content components) should be pre-rendered in the calling page
 * using `render()` from 'astro:content' and passed via the renderedBodies map.
 */
interface Promotion {
  title: string;
  date: string;
}

interface Highlight {
  title: string;
  description: string;
}

interface ExperienceEntry {
  id: string;
  body?: string;
  data: {
    company: string;
    title: string;
    startDate: string;
    endDate: string | null;
    sortOrder: number;
    category: 'professional' | 'other';
    summary: string;
    promotions?: Promotion[];
    highlights?: Highlight[];
  };
}

interface Props {
  entries: ExperienceEntry[];
  isFull: boolean;
  renderedBodies?: Map<string, any>;
}

const { entries, isFull, renderedBodies = new Map() } = Astro.props;

function formatDateRange(start: string, end: string | null): string {
  const formatMonth = (dateStr: string) => {
    const [year, month] = dateStr.split('-');
    const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    return `${months[parseInt(month) - 1]} ${year}`;
  };
  return `${formatMonth(start)} \u2013 ${end ? formatMonth(end) : 'Present'}`;
}
---

<section class="resume-experience">
  <h2 class="section-heading">Experience</h2>
  {entries.map((entry) => {
    const Content = renderedBodies.get(entry.id);
    return (
      <div class="experience-entry">
        <div class="entry-header">
          <div class="entry-title-block">
            <span class="entry-title">{entry.data.title}</span>
            <span class="entry-company"> | {entry.data.company}</span>
          </div>
          <span class="entry-date">{formatDateRange(entry.data.startDate, entry.data.endDate)}</span>
        </div>
        <p class="entry-summary">{entry.data.summary}</p>

        {isFull && entry.data.promotions && entry.data.promotions.length > 0 && (
          <div class="entry-promotions">
            <span class="promotions-label">Promotions:</span>
            {entry.data.promotions.map((p: Promotion, i: number) => (
              <span>
                {p.title} ({p.date}){i < entry.data.promotions!.length - 1 ? ', ' : ''}
              </span>
            ))}
          </div>
        )}

        {isFull && entry.data.highlights && entry.data.highlights.length > 0 && (
          <ul class="entry-highlights">
            {entry.data.highlights.map((h: Highlight) => (
              <li>
                <strong>{h.title}:</strong> {h.description}
              </li>
            ))}
          </ul>
        )}

        {isFull && Content && (
          <div class="entry-body">
            <Content />
          </div>
        )}
      </div>
    );
  })}
</section>

<style>
  .resume-experience {
    margin-bottom: 0.75rem;
  }

  .section-heading {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #0E5484;
    border-bottom: 1.5px solid #0E5484;
    padding-bottom: 0.15rem;
    margin: 0 0 0.5rem 0;
    break-after: avoid;
  }

  .experience-entry {
    margin-bottom: 0.5rem;
    break-inside: avoid;
  }

  .entry-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
  }

  .entry-title-block {
    flex: 1;
    min-width: 0;
  }

  .entry-title {
    font-weight: 700;
    font-size: 0.75rem;
    color: #2d2d2d;
  }

  .entry-company {
    font-size: 0.7rem;
    color: #0E5484;
    font-weight: 600;
  }

  .entry-date {
    font-family: 'Source Code Pro', 'Source Code Pro Variable', monospace;
    font-size: 0.6rem;
    color: #666;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .entry-summary {
    font-size: 0.65rem;
    color: #444;
    margin: 0.1rem 0 0 0;
    line-height: 1.4;
  }

  .entry-promotions {
    font-size: 0.6rem;
    color: #555;
    margin-top: 0.15rem;
    font-style: italic;
  }

  .promotions-label {
    font-weight: 600;
    font-style: normal;
  }

  .entry-highlights {
    margin: 0.2rem 0 0 1rem;
    padding: 0;
    list-style: disc;
    font-size: 0.6rem;
    color: #444;
    line-height: 1.4;
  }

  .entry-highlights li {
    margin-bottom: 0.1rem;
  }

  .entry-body {
    margin-top: 0.25rem;
    font-size: 0.6rem;
    color: #444;
    line-height: 1.4;
  }

  .entry-body :global(h2) {
    font-size: 0.65rem;
    font-weight: 700;
    color: #0E5484;
    margin: 0.3rem 0 0.1rem 0;
  }

  .entry-body :global(ul) {
    margin: 0.1rem 0 0.1rem 1rem;
    padding: 0;
    list-style: disc;
  }

  .entry-body :global(li) {
    margin-bottom: 0.05rem;
  }

  .entry-body :global(strong) {
    color: #2d2d2d;
  }
</style>
