---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={`/blog/${post.id}`}
  class="bg-rp-surface rounded-xl border border-rp-highlight-med hover:border-rp-rose/50 hover:-translate-y-1 transition-all duration-300 p-5 block no-underline"
>
  <div class="text-xs text-rp-muted mb-2 flex gap-3">
    <span>{formattedDate}</span>
    <span>{post.data.readingTime}</span>
  </div>

  <h3 class="text-lg font-semibold text-rp-text mb-2">{post.data.title}</h3>

  <p class="text-sm text-rp-subtle leading-relaxed mb-3">{post.data.excerpt}</p>

  <div class="flex flex-wrap gap-2">
    {post.data.categories.map(category => (
      <span class="text-xs px-2.5 py-0.5 rounded-full font-mono bg-rp-pine/20 text-rp-pine">
        {category}
      </span>
    ))}
    {post.data.tags.map(tag => (
      <span class="text-xs px-2.5 py-0.5 rounded-full font-mono bg-rp-highlight-low text-rp-subtle">
        {tag}
      </span>
    ))}
  </div>
</a>
