---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Jordan Garrison">
  <div class="max-w-4xl mx-auto">

    <!-- Hero Section -->
    <section class="flex flex-col sm:flex-row items-center gap-8 mb-16">
      <img
        src="https://avatars.githubusercontent.com/u/22905777?v=4"
        alt="Jordan Garrison"
        class="w-48 h-48 rounded-full border-4 border-rp-highlight-med object-cover shrink-0"
      />
      <div class="text-center sm:text-left">
        <h1 class="text-4xl sm:text-5xl font-bold text-rp-text mb-3">
          Hi, I'm Jordan
        </h1>
        <p class="text-lg text-rp-subtle">
          Engineer | Lifelong learner. Relentlessly curious.
        </p>
      </div>
    </section>

    <!-- Intro Section -->
    <section class="mb-16">
      <div class="bg-rp-surface rounded-xl p-6">
        <p class="text-rp-text leading-relaxed mb-4">
          Passionate about my family, Open Source, Linux, Jiu Jitsu, and being actively involved in my local church.
        </p>
        <p class="italic text-rp-iris">
          <a href="https://grugbrain.dev" target="_blank" rel="noopener noreferrer" class="text-rp-iris hover:text-rp-iris/80 no-underline hover:underline">
            "Complexity very bad. Say no to complexity."
          </a>
        </p>
      </div>
    </section>

    <!-- My Journey Timeline -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold text-rp-text mb-6 pb-2 border-b border-rp-highlight-med">
        My Journey
      </h2>
      <div class="border-l-2 border-rp-rose ml-4 pl-8 space-y-8">
        <!-- FloSports -->
        <a href="/experience#flosports" class="block group relative hover:-translate-y-0.5 transition-transform duration-200">
          <div class="absolute -left-[2.6rem] top-1.5 w-3 h-3 rounded-full bg-rp-rose ring-4 ring-rp-base"></div>
          <p class="text-sm font-mono text-rp-muted mb-1">2019&ndash;Present</p>
          <h3 class="text-lg font-semibold text-rp-text group-hover:text-rp-rose transition-colors">FloSports</h3>
          <p class="text-rp-subtle leading-relaxed">
            From Infrastructure Engineer to Tech Lead, SRE. Building developer platforms, driving cloud migrations, and establishing SRE practices.
          </p>
        </a>

        <!-- General Motors -->
        <a href="/experience#gm" class="block group relative hover:-translate-y-0.5 transition-transform duration-200">
          <div class="absolute -left-[2.6rem] top-1.5 w-3 h-3 rounded-full bg-rp-rose ring-4 ring-rp-base"></div>
          <p class="text-sm font-mono text-rp-muted mb-1">2017&ndash;2019</p>
          <h3 class="text-lg font-semibold text-rp-text group-hover:text-rp-rose transition-colors">General Motors</h3>
          <p class="text-rp-subtle leading-relaxed">
            Big Data Platform Engineer managing 15PB Hadoop clusters. Built monitoring systems, security frameworks, and automation tools in Go and Python.
          </p>
        </a>

        <!-- Lynntech -->
        <a href="/experience#lynntech" class="block group relative hover:-translate-y-0.5 transition-transform duration-200">
          <div class="absolute -left-[2.6rem] top-1.5 w-3 h-3 rounded-full bg-rp-rose ring-4 ring-rp-base"></div>
          <p class="text-sm font-mono text-rp-muted mb-1">2016&ndash;2017</p>
          <h3 class="text-lg font-semibold text-rp-text group-hover:text-rp-rose transition-colors">Lynntech</h3>
          <p class="text-rp-subtle leading-relaxed">
            Research Technician building IoT prototypes with Python, Arduino, and Raspberry Pi. Hardware meets software.
          </p>
        </a>

        <!-- Texas A&M -->
        <div class="relative">
          <div class="absolute -left-[2.6rem] top-1.5 w-3 h-3 rounded-full bg-rp-rose ring-4 ring-rp-base"></div>
          <p class="text-sm font-mono text-rp-muted mb-1">2012&ndash;2017</p>
          <h3 class="text-lg font-semibold text-rp-text">Texas A&amp;M University</h3>
          <p class="text-rp-subtle leading-relaxed">
            B.S. Physics with Math Minor. Started with Higgs Boson simulations in the Department of Physics and Astronomy, running C++ and Bash on distributed computing clusters.
          </p>
        </div>
      </div>
    </section>

    <!-- Skills Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold text-rp-text mb-6 pb-2 border-b border-rp-highlight-med">
        Skills
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
        <!-- Languages -->
        <div class="bg-rp-surface rounded-xl p-5">
          <h3 class="text-lg font-semibold text-rp-text mb-3">Languages</h3>
          <div class="flex flex-wrap gap-2">
            {['Go', 'TypeScript', 'Python', 'Bash', 'Ruby'].map((skill) => (
              <span class="font-mono text-sm px-3 py-1 rounded-full bg-rp-pine/20 text-rp-pine">
                {skill}
              </span>
            ))}
          </div>
        </div>

        <!-- Platforms -->
        <div class="bg-rp-surface rounded-xl p-5">
          <h3 class="text-lg font-semibold text-rp-text mb-3">Platforms</h3>
          <div class="flex flex-wrap gap-2">
            {['Kubernetes', 'Istio', 'Argo', 'Fastly', 'Kafka'].map((skill) => (
              <span class="font-mono text-sm px-3 py-1 rounded-full bg-rp-foam/20 text-rp-foam">
                {skill}
              </span>
            ))}
          </div>
        </div>

        <!-- Infrastructure as Code -->
        <div class="bg-rp-surface rounded-xl p-5">
          <h3 class="text-lg font-semibold text-rp-text mb-3">Infrastructure as Code</h3>
          <div class="flex flex-wrap gap-2">
            {['Terraform', 'CDK', 'Helm', 'Kustomize', 'Nix'].map((skill) => (
              <span class="font-mono text-sm px-3 py-1 rounded-full bg-rp-iris/20 text-rp-iris">
                {skill}
              </span>
            ))}
          </div>
        </div>

        <!-- Observability -->
        <div class="bg-rp-surface rounded-xl p-5">
          <h3 class="text-lg font-semibold text-rp-text mb-3">Observability</h3>
          <div class="flex flex-wrap gap-2">
            {['Datadog', 'Prometheus', 'Grafana', 'ELK'].map((skill) => (
              <span class="font-mono text-sm px-3 py-1 rounded-full bg-rp-gold/20 text-rp-gold">
                {skill}
              </span>
            ))}
          </div>
        </div>
      </div>

      <!-- Linux note -->
      <div class="border-2 border-dashed border-rp-highlight-med rounded-xl p-5 text-center">
        <p class="text-rp-subtle italic">
          Linux? Yes please! Especially love NixOS.
        </p>
      </div>
    </section>

    <!-- Awards & Certifications -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold text-rp-text mb-6 pb-2 border-b border-rp-highlight-med">
        Awards &amp; Certifications
      </h2>
      <ul class="divide-y divide-rp-highlight-low">
        <li class="py-3 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
          <span class="text-rp-text font-medium">Advanced GitOps Certification</span>
          <span class="text-sm text-rp-muted">Akuity, 2024</span>
        </li>
        <li class="py-3 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
          <span class="text-rp-text font-medium">Promotion to Tech Lead</span>
          <span class="text-sm text-rp-muted">FloSports, 2023</span>
        </li>
        <li class="py-3 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
          <span class="text-rp-text font-medium">Top Performer - Own It Award</span>
          <span class="text-sm text-rp-muted">FloSports, 2021</span>
        </li>
        <li class="py-3 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
          <span class="text-rp-text font-medium">Promotion to Senior Infrastructure Engineer</span>
          <span class="text-sm text-rp-muted">FloSports, 2021</span>
        </li>
        <li class="py-3 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
          <span class="text-rp-text font-medium">CEO Life Saving Award &amp; CIO Safety Award</span>
          <span class="text-sm text-rp-muted">General Motors, 2019</span>
        </li>
        <li class="py-3 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
          <span class="text-rp-text font-medium">Early Promotion from New College Hire Program</span>
          <span class="text-sm text-rp-muted">General Motors, 2019</span>
        </li>
        <li class="py-3 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
          <span class="text-rp-text font-medium">CIO Distinguished New College Hire</span>
          <span class="text-sm text-rp-muted">General Motors, 2018 &amp; 2019</span>
        </li>
      </ul>
    </section>

  </div>
</BaseLayout>
