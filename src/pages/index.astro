---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const professional = (await getCollection('experience'))
  .filter((e) => e.data.category === 'professional')
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const skills = (await getCollection('skills'))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const awards = (await getCollection('awards'))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const certifications = (await getCollection('certifications'))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const education = (await getCollection('education'))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

function formatYearRange(start: string, end: string | null): string {
  const startYear = start.split('-')[0];
  const endYear = end ? end.split('-')[0] : 'Present';
  return `${startYear}\u2013${endYear}`;
}

function formatAwardYears(years: number[]): string {
  if (years.length === 1) return String(years[0]);
  return years.join(' & ');
}

function formatCertDate(date: string): string {
  const [year] = date.split('-');
  return year;
}

// Cycle through Rose Pine accent colors for skill categories
const skillColors = [
  { bg: 'bg-rp-pine/20', text: 'text-rp-pine' },
  { bg: 'bg-rp-foam/20', text: 'text-rp-foam' },
  { bg: 'bg-rp-iris/20', text: 'text-rp-iris' },
  { bg: 'bg-rp-gold/20', text: 'text-rp-gold' },
  { bg: 'bg-rp-rose/20', text: 'text-rp-rose' },
  { bg: 'bg-rp-love/20', text: 'text-rp-love' },
];
---

<BaseLayout title="Jordan Garrison">
  <div class="max-w-4xl mx-auto">

    <!-- Hero Section -->
    <section class="flex flex-col sm:flex-row items-center gap-8 mb-16">
      <img
        src="https://avatars.githubusercontent.com/u/22905777?v=4"
        alt="Jordan Garrison"
        class="w-48 h-48 rounded-full border-4 border-rp-highlight-med object-cover shrink-0"
      />
      <div class="text-center sm:text-left">
        <h1 class="text-4xl sm:text-5xl font-bold text-rp-text mb-3">
          Hi, I'm Jordan
        </h1>
        <p class="text-lg text-rp-subtle">
          Engineer | Lifelong learner. Relentlessly curious.
        </p>
      </div>
    </section>

    <!-- Intro Section -->
    <section class="mb-16">
      <div class="bg-rp-surface rounded-xl p-6">
        <p id="tagline" class="font-mono text-lg font-semibold text-rp-text leading-relaxed mb-4"></p>
        <p class="italic text-rp-iris">
          <a href="https://grugbrain.dev" target="_blank" rel="noopener noreferrer" class="text-rp-iris hover:text-rp-iris/80 no-underline hover:underline">
            "Complexity very bad. Say no to complexity."
          </a>
        </p>
      </div>
    </section>

    <!-- My Journey Timeline -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold text-rp-text mb-6 pb-2 border-b border-rp-highlight-med">
        My Journey
      </h2>
      <div class="border-l-2 border-rp-rose ml-4 pl-8 space-y-8">
        {professional.map((entry) => (
          <a href={`/experience#${entry.id}`} class="block group relative hover:-translate-y-0.5 transition-transform duration-200">
            <div class="absolute -left-[2.6rem] top-1.5 w-3 h-3 rounded-full bg-rp-rose ring-4 ring-rp-base"></div>
            <p class="text-sm font-mono text-rp-muted mb-1">{formatYearRange(entry.data.startDate, entry.data.endDate)}</p>
            <h3 class="text-lg font-semibold text-rp-text group-hover:text-rp-rose transition-colors">{entry.data.company}</h3>
            <p class="text-rp-subtle leading-relaxed">{entry.data.summary}</p>
          </a>
        ))}

        {/* Education */}
        {education.map((edu) => (
          <div class="relative">
            <div class="absolute -left-[2.6rem] top-1.5 w-3 h-3 rounded-full bg-rp-rose ring-4 ring-rp-base"></div>
            <p class="text-sm font-mono text-rp-muted mb-1">{edu.data.startYear}&ndash;{edu.data.endYear}</p>
            <h3 class="text-lg font-semibold text-rp-text">{edu.data.institution}</h3>
            <p class="text-rp-subtle leading-relaxed">
              {edu.data.degree} in {edu.data.major}{edu.data.minor ? ` with ${edu.data.minor} Minor` : ''}
            </p>
          </div>
        ))}
      </div>
    </section>

    <!-- Skills Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold text-rp-text mb-6 pb-2 border-b border-rp-highlight-med">
        Skills
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
        {skills.map((skill, i) => {
          const color = skillColors[i % skillColors.length];
          return (
            <div class="bg-rp-surface rounded-xl p-5">
              <h3 class="text-lg font-semibold text-rp-text mb-3">{skill.data.name}</h3>
              <div class="flex flex-wrap gap-2">
                {skill.data.items.map((item) => (
                  <span class:list={['font-mono text-sm px-3 py-1 rounded-full', color.bg, color.text]}>
                    {item}
                  </span>
                ))}
              </div>
              {skill.data.note && (
                <p class="text-rp-subtle italic mt-3 text-sm">{skill.data.note}</p>
              )}
            </div>
          );
        })}
      </div>
    </section>

    <!-- Awards & Certifications -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold text-rp-text mb-6 pb-2 border-b border-rp-highlight-med">
        Awards &amp; Certifications
      </h2>
      <ul class="divide-y divide-rp-highlight-low">
        {certifications.map((cert) => (
          <li class="py-3 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
            <span class="text-rp-text font-medium">{cert.data.name}</span>
            <span class="text-sm text-rp-muted">{formatCertDate(cert.data.date)}</span>
          </li>
        ))}
        {awards.map((award) => (
          <li class="py-3 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
            <span class="text-rp-text font-medium">{award.data.title}</span>
            <span class="text-sm text-rp-muted">{award.data.organization}, {formatAwardYears(award.data.years)}</span>
          </li>
        ))}
      </ul>
    </section>

  </div>
</BaseLayout>

<script>
  const taglines = [
    "I build platforms that make engineers fast and infrastructure boring.",
    "I tame infrastructure complexity so your engineers can focus on the product.",
    "I turn \"we need SRE to do that\" into \"I just deployed it myself.\"",
    "I build the platforms that turn infrastructure from a bottleneck into a superpower.",
  ];
  const el = document.getElementById('tagline');
  if (el) el.textContent = taglines[Math.floor(Math.random() * taglines.length)];
</script>
