---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    date: Date;
    excerpt: string;
    categories: string[];
    tags: string[];
    readingTime: string;
  };
}

const { frontmatter } = Astro.props;

const formattedDate = frontmatter.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={frontmatter.title + ' - Jordan Garrison'}>
  <div class="max-w-3xl mx-auto">
    <!-- Back link -->
    <a
      href="/blog"
      class="inline-flex items-center gap-1 text-sm text-rp-muted hover:text-rp-text transition-colors mb-8 no-underline"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M19 12H5"></path>
        <path d="M12 19l-7-7 7-7"></path>
      </svg>
      Back to Blog
    </a>

    <!-- Post header -->
    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-rp-text mb-4 leading-tight">
        {frontmatter.title}
      </h1>

      <div class="text-sm text-rp-muted flex gap-4 mb-4">
        <time datetime={frontmatter.date.toISOString()}>{formattedDate}</time>
        <span>{frontmatter.readingTime}</span>
      </div>

      <div class="flex flex-wrap gap-2">
        {frontmatter.categories.map(category => (
          <span class="text-xs px-2.5 py-0.5 rounded-full font-mono bg-rp-pine/20 text-rp-pine">
            {category}
          </span>
        ))}
        {frontmatter.tags.map(tag => (
          <span class="text-xs px-2.5 py-0.5 rounded-full font-mono bg-rp-highlight-low text-rp-subtle">
            {tag}
          </span>
        ))}
      </div>
    </header>

    <!-- Content area with prose styling -->
    <article class="blog-prose prose max-w-none">
      <slot />
    </article>

    <!-- Footer -->
    <footer class="mt-12 pt-8 border-t border-rp-highlight-med">
      <a
        href="/blog"
        class="inline-flex items-center gap-1 text-sm text-rp-muted hover:text-rp-text transition-colors no-underline"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M19 12H5"></path>
          <path d="M12 19l-7-7 7-7"></path>
        </svg>
        Back to Blog
      </a>
    </footer>
  </div>
</BaseLayout>

<style is:global>
  .blog-prose {
    /* Base text */
    color: var(--rp-text);

    /* Headings */
    & h1, & h2, & h3, & h4, & h5, & h6 {
      color: var(--rp-text);
    }

    /* Links */
    & a {
      color: var(--rp-rose);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    & a:hover {
      color: var(--rp-love);
    }

    /* Bold */
    & strong {
      color: var(--rp-text);
    }

    /* Inline code */
    & :not(pre) > code {
      background-color: var(--rp-overlay);
      color: var(--rp-rose);
      padding: 0.125rem 0.375rem;
      border-radius: 0.25rem;
      font-size: 0.875em;
    }
    & :not(pre) > code::before,
    & :not(pre) > code::after {
      content: none;
    }

    /* Code blocks — always dark regardless of theme */
    & pre {
      background-color: #191724 !important;
      border-radius: 0.5rem;
      border: 1px solid #26233a;
    }
    & pre code {
      color: #e0def4;
      background-color: transparent;
      padding: 0;
      font-size: 0.875em;
    }

    /* Blockquotes */
    & blockquote {
      border-left-color: var(--rp-highlight-med);
      color: var(--rp-subtle);
      font-style: italic;
    }

    /* Pullquotes — magazine-style callout */
    & aside.pullquote {
      border-top: 3px solid var(--rp-rose);
      border-bottom: 3px solid var(--rp-rose);
      margin: 2rem auto;
      padding: 1.5rem 2rem;
      font-size: 1.3rem;
      line-height: 1.6;
      font-style: italic;
      font-weight: 500;
      color: var(--rp-iris);
      text-align: center;
      max-width: 85%;
    }

    /* Horizontal rules */
    & hr {
      border-color: var(--rp-highlight-med);
    }

    /* List markers */
    & ul > li::marker {
      color: var(--rp-muted);
    }
    & ol > li::marker {
      color: var(--rp-muted);
    }

    /* Paragraphs */
    & p {
      color: var(--rp-text);
    }

    /* List items */
    & li {
      color: var(--rp-text);
    }
  }
</style>
