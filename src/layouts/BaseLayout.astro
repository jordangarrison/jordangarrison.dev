---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  fullWidth?: boolean;
}

const {
  title,
  description = 'Jordan Garrison — Engineer, lifelong learner, relentlessly curious.',
  fullWidth = false,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title="jordangarrison.dev" href="/rss.xml" />
    <title>{title}</title>
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme');
        const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        const theme = saved || preferred;
        document.documentElement.classList.remove('light', 'dark');
        document.documentElement.classList.add(theme);
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Navbar />
    <main class:list={['flex-1 w-full mx-auto px-4 sm:px-6 py-8', fullWidth ? '' : 'max-w-5xl']}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
